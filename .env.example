# Web server
OWLGORITHM_PORT=3847
OWLGORITHM_HOST=127.0.0.1
OWLGORITHM_BASE_PATH=/
OWLGORITHM_PUBLIC_URL=http://127.0.0.1:3847
# Optional runtime data directory for SQLite and scraper cache.
# Example production value: /var/data/owlgorithm
# OWLGORITHM_DATA_DIR=server/data

# Frontend
# Leave blank for same-origin API requests in production.
VITE_API_BASE_URL=
OWLGORITHM_DEV_API_TARGET=http://127.0.0.1:3847
# Set only for static GitHub Pages preview builds without a Node API.
VITE_STATIC_PREVIEW=0
# Optional iOS URL scheme registered by the native wrapper for ASWebAuthenticationSession callbacks.
VITE_IOS_CALLBACK_SCHEME=

# Firebase Auth public web config. These are public client identifiers, not secrets.
FIREBASE_PROJECT_ID=owlgorithm-fdc26
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Scraper
ENABLE_SCRAPER=true
SCRAPE_INTERVAL_MS=7200000

# Optional admin protection for manual scrape triggers
OWLGORITHM_ADMIN_TOKEN=

# Transactional email
OWLGORITHM_EMAIL_FROM="Owlgorithm <no-reply@example.com>"
OWLGORITHM_SMTP_HOST=
OWLGORITHM_SMTP_PORT=587
OWLGORITHM_SMTP_USER=
OWLGORITHM_SMTP_PASSWORD=
OWLGORITHM_SMTP_SECURE=false

# Private media generation
# Creator Studio accepts the OWLGORITHM_MEDIA_* names below, or xAI/Grok aliases.
OWLGORITHM_MEDIA_API_KEY=
OWLGORITHM_MEDIA_API_BASE_URL=
OWLGORITHM_MEDIA_IMAGE_MODEL=
OWLGORITHM_MEDIA_VIDEO_MODEL=

# xAI/Grok defaults used when XAI_API_KEY or GROK_API_KEY is present.
XAI_API_KEY=
GROK_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_IMAGE_MODEL=grok-imagine-image-quality
XAI_VIDEO_MODEL=grok-imagine-video

# Support Owl chat. Defaults to xAI when a Grok key is present.
OWLGORITHM_SUPPORT_API_KEY=
OWLGORITHM_SUPPORT_API_BASE_URL=https://api.x.ai/v1
OWLGORITHM_SUPPORT_MODEL=grok-4.3

# Upload-Post social publishing. The master key is server-side only.
UPLOAD_POST_API_KEY=
UPLOAD_POST_API_BASE_URL=https://api.upload-post.com/api
UPLOAD_POST_PROFILE_USERNAME=
UPLOAD_POST_AUTH_SCHEME=Apikey
UPLOAD_POST_TIMEZONE=America/New_York
UPLOAD_POST_CONNECT_PLATFORMS=tiktok,instagram,linkedin,facebook,x,threads,google_business
UPLOAD_POST_FACEBOOK_PAGE_ID=
UPLOAD_POST_LINKEDIN_PAGE_ID=
UPLOAD_POST_PINTEREST_BOARD_ID=
UPLOAD_POST_REDDIT_SUBREDDIT=
UPLOAD_POST_GOOGLE_BUSINESS_LOCATION_ID=
UPLOAD_POST_TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE
UPLOAD_POST_TIKTOK_AUTO_ADD_MUSIC=true
UPLOAD_POST_INSTAGRAM_VIDEO_MEDIA_TYPE=REELS
UPLOAD_POST_INSTAGRAM_PHOTO_MEDIA_TYPE=IMAGE
UPLOAD_POST_FACEBOOK_MEDIA_TYPE=REELS
UPLOAD_POST_YOUTUBE_PRIVACY_STATUS=public
UPLOAD_POST_YOUTUBE_CATEGORY_ID=28
UPLOAD_POST_YOUTUBE_TAGS=AI,productivity,automation,Delphi Labs,Owlgorithm
