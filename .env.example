# Web server
OWLGORITHM_PORT=3847
OWLGORITHM_HOST=127.0.0.1
OWLGORITHM_BASE_PATH=/
OWLGORITHM_PUBLIC_URL=http://127.0.0.1:3847
# Optional runtime data directory for SQLite and scraper cache.
# Example production value: /var/data/owlgorithm
# OWLGORITHM_DATA_DIR=server/data

# Frontend
# Leave blank for same-origin API requests in production.
VITE_API_BASE_URL=
OWLGORITHM_DEV_API_TARGET=http://127.0.0.1:3847
# Set only for static GitHub Pages preview builds without a Node API.
VITE_STATIC_PREVIEW=0

# Scraper
ENABLE_SCRAPER=true
SCRAPE_INTERVAL_MS=7200000

# Optional admin protection for manual scrape triggers
OWLGORITHM_ADMIN_TOKEN=

# Transactional email
OWLGORITHM_EMAIL_FROM="Owlgorithm <no-reply@example.com>"
OWLGORITHM_SMTP_HOST=
OWLGORITHM_SMTP_PORT=587
OWLGORITHM_SMTP_USER=
OWLGORITHM_SMTP_PASSWORD=
OWLGORITHM_SMTP_SECURE=false

# Private media generation
OWLGORITHM_MEDIA_API_KEY=
OWLGORITHM_MEDIA_API_BASE_URL=
OWLGORITHM_MEDIA_IMAGE_MODEL=
OWLGORITHM_MEDIA_VIDEO_MODEL=

# Private social publishing
OWLGORITHM_SOCIAL_API_KEY=
OWLGORITHM_SOCIAL_PROFILE=
OWLGORITHM_SOCIAL_API_BASE_URL=
OWLGORITHM_SOCIAL_AUTH_SCHEME=Apikey
OWLGORITHM_SOCIAL_TIMEZONE=America/New_York
OWLGORITHM_SOCIAL_FACEBOOK_PAGE_ID=
OWLGORITHM_SOCIAL_LINKEDIN_PAGE_ID=
OWLGORITHM_SOCIAL_PINTEREST_BOARD_ID=
OWLGORITHM_SOCIAL_REDDIT_SUBREDDIT=
OWLGORITHM_SOCIAL_GOOGLE_BUSINESS_LOCATION_ID=
OWLGORITHM_SOCIAL_UPLOAD_ENDPOINT=
OWLGORITHM_SOCIAL_PHOTO_ENDPOINT=
OWLGORITHM_SOCIAL_TEXT_ENDPOINT=
OWLGORITHM_SOCIAL_STATUS_ENDPOINT=
